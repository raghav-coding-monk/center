{
  "version": 2,
  "builds": [
    {
      "src": "backend/db.js",
      "use": "@vercel/node"
    },
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "public" } 
    }
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/backend/db.js"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}